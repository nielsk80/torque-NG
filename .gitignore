# =============================================================================
# torque-NG Modern Build Rules
# =============================================================================
# Ignore the new centralized build tree
build/

# Ignore Protobuf generated source/headers if they appear in the source tree
*.pb.cc
*.pb.h

# Modern IDE and Editor temporary files
.vscode/
.idea/
*.swp
.DS_Store

# =============================================================================
# Legacy TORQUE Rules (Preserved)
# =============================================================================
# Ignore objects and archives.
*.[oa]
Makefile
Makefile.in
test_uut
*.l[oa]
*.gcno
*.gcov
*.gcda
*_suite.log
.deps
.dirstamp
.libs
*~
*.m4
*.log
*.trs
*.tmp
.settings
autom4te.cache/
buildutils/ar-lib
buildutils/compile
buildutils/config.guess
buildutils/config.sub
buildutils/depcomp
buildutils/install-sh
buildutils/ltmain.sh
buildutils/missing
buildutils/modulefiles
buildutils/modulefiles.vers
buildutils/pbs_mkdirs
buildutils/self-extract-head-sh
buildutils/ylwrap
buildutils/test-driver
config.log
config.status
configure

# ... (All other existing legacy rules preserved below)
# Indexing files
cscope.out
src/cscope.out
tags
src/tags

# Generated site headers
src/include/site_*.h
src/include/pbs_config.h
